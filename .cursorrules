### Advanced Figma API Patterns

#### Viewport and Navigation:

```typescript
// ✅ Smart viewport management
function focusOnCreatedNodes(nodes: SceneNode[]): void {
  if (nodes.length === 0) return;
  
  // Set selection first
  figma.currentPage.selection = nodes;
  
  // Then adjust viewport
  figma.viewport.scrollAndZoomIntoView(nodes);
  
  // Optional: Add slight zoom padding
  const bounds = nodes[0].absoluteBoundingBox;
  if (bounds && nodes.length === 1) {
    const padding = Math.min(bounds.width, bounds.height) * 0.2;
    // Custom zoom logic here
  }
}
```

#### Custom Property Management:

```typescript
// ✅ Plugin data storage patterns
const PLUGIN_NAMESPACE = 'your-plugin-name';

function setPluginData(node: SceneNode, key: string, value: any): void {
  node.setPluginData(key, JSON.stringify(value));
}

function getPluginData<T>(node: SceneNode, key: string): T | null {
  const data = node.getPluginData(key);
  return data ? JSON.parse(data) : null;
}

// Shared data across plugin instances
function setSharedData(key: string, value: any): void {
  figma.root.setSharedPluginData(PLUGIN_NAMESPACE, key, JSON.stringify(value));
}

function getSharedData<T>(key: string): T | null {
  const data = figma.root.getSharedPluginData(PLUGIN_NAMESPACE, key);
  return data ? JSON.parse(data) : null;
}
```

These patterns ensure robust, performant, and user-friendly Figma plugins that handle edge cases gracefully and provide excellent developer experience.

