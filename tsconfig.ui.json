{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "@types/react", "@types/react-dom"],
    "jsx": "react-jsx",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "moduleResolution": "bundler"
  },
  "include": [
    "src/ui/**/*",
    "src/common/**/*"
  ],
  "exclude": [
    "src/plugin/**/*",
    "node_modules",
    "dist"
  ]
}

